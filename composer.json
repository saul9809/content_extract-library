{
  "name": "tuorganizacion/content-processor",
  "description": "Librería PHP para procesar y estructurar contenido de documentos en JSON. Framework-agnostic, batch-ready, production-ready.",
  "keywords": [
    "pdf",
    "content-extraction",
    "document-processing",
    "batch-processing",
    "json-schema",
    "php",
    "psr-4"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Tu Nombre",
      "email": "tu@email.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "smalot/pdfparser": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "ContentProcessor\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ContentProcessor\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs src/ --standard=PSR12"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
